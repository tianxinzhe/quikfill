{
  "manifest_version": 3,
  "name": "QuickFill",
  "version": "1.0.0",
  "description": "绝对隐私、纯本地运行、可视化卡片操作的 Chrome 侧边栏快捷文本填充工具",
  "permissions": ["sidePanel", "storage", "activeTab", "contextMenus", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "打开/关闭 QuickFill 侧边栏"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "QuickFill"
  }
}